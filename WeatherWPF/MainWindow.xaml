<Window x:Class="WeatherWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Погода" Height="680" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="🌤 Погода"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="cityTextBox"
                     Width="270" Height="32"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="6,0"
                     KeyDown="CityTextBox_KeyDown"/>
            <Button x:Name="searchButton"
                    Content="Найти"
                    Width="76" Height="32"
                    Margin="6,0,0,0"
                    FontSize="13"
                    Click="SearchButton_Click"/>
            <Button Content="История"
                    Width="76" Height="32"
                    Margin="6,0,0,0"
                    FontSize="12"
                    Click="HistoryButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="errorTextBlock"
                   Grid.Row="2"
                   Visibility="Collapsed"
                   Foreground="Red" FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"
                   TextAlignment="Center"/>

        <Border Grid.Row="3"
                BorderBrush="#BBBBBB" BorderThickness="1"
                CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock x:Name="hintTextBlock"
                               Text="Введите название города и нажмите «Найти»"
                               Foreground="Gray" FontSize="13"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0"/>

                    <TextBlock x:Name="loadingTextBlock"
                               Text="⏳ Загрузка..."
                               Visibility="Collapsed"
                               FontSize="14" Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0"/>

                    <StackPanel x:Name="weatherPanel" Visibility="Collapsed">

                        <TextBlock x:Name="cityNameTextBlock"
                                   FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2"/>

                        <Image x:Name="weatherIcon"
                               Width="64" Height="64"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,4"/>

                        <TextBlock x:Name="tempTextBlock"
                                   FontSize="38" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2"/>

                        <TextBlock x:Name="feelsLikeTextBlock"
                                   FontSize="12" Foreground="#777777"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>

                        <TextBlock x:Name="descTextBlock"
                                   FontSize="14" Foreground="#444444"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <Separator Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="💧 Влажность"
                                           FontSize="11" Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="humidityTextBlock"
                                           FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="💨 Ветер"
                                           FontSize="11" Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="windTextBlock"
                                           FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="🔵 Давление"
                                           FontSize="11" Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="pressureTextBlock"
                                           FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="saveButton"
                                Content="В избранное"
                                HorizontalAlignment="Center"
                                Padding="12,4"
                                Margin="0,0,0,14"
                                Click="SaveButton_Click"/>

                        <Separator Margin="0,0,0,10"/>

                        <TextBlock Text="Прогноз на 5 дней"
                                   FontSize="13" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <ItemsControl x:Name="forecastList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                                            Padding="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DateLabel}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <Image Grid.Column="1"
                                                   Source="{Binding IconUrl}"
                                                   Width="30" Height="30"/>
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       FontSize="13">
                                                <Run Text="{Binding MaxTemp}" FontWeight="SemiBold"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding MinTemp}" Foreground="Gray"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel x:Name="historyPanel" Visibility="Collapsed" Margin="0,8,0,0">
                        <TextBlock x:Name="panelTitleTextBlock"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <ListBox x:Name="historyListBox"
                                 Height="160"
                                 SelectionChanged="HistoryListBox_SelectionChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Удалить"
                                    Width="80" Height="26"
                                    Click="RemoveItemButton_Click"/>
                            <Button Content="Закрыть"
                                    Width="80" Height="26"
                                    Margin="8,0,0,0"
                                    Click="ClosePanel_Click"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Избранное: "
                           FontSize="12" Foreground="Gray"
                           VerticalAlignment="Center"/>
                <Button Content="Показать"
                        FontSize="11" Padding="6,2"
                        Click="ShowFavoritesButton_Click"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>